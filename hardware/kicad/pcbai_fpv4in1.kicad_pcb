		(6 "In2.Cu" signal "Inner signal #2 (NEW 10L) — dedicated J18/J19 fan-in escape layer")
		(8 "In3.Cu" signal "GND plane #2 (NEW 10L) — brackets In2 escape signals; signal-typed for DSN export; Phase 5c re-classifies to power")
		(10 "In4.Cu" signal "Inner signal #4 — BEMF analog (shielded by In3 + In5, OQ-016)")
		(12 "In5.Cu" signal "+VMOTOR plane (3oz, ≥280A bus; moved from In3 in 8L); signal-typed for DSN export; Phase 5c re-classifies to power")

		(16 "In7.Cu" signal "GND plane #3 (NEW 10L) — brackets In6 + In8 signals; signal-typed for DSN export; Phase 5c re-classifies to power")
		(18 "In8.Cu" signal "Inner signal #8 (NEW 10L) — PWM_IN stragglers + low-current overflow")
		(2 "B.Cu" signal "B.Cu 1oz — LS FETs, bulk caps, status LEDs")

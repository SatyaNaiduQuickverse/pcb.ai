(footprint "BatterySolderPad_5x5_THT2.0_HC"
	(version 20241229)
	(generator "pcbnew")
	(generator_version "9.0")
	(layer "F.Cu")
	(descr "High-current battery solder pad — 5x5mm copper on F.Cu+B.Cu, 2mm THT plated hole for hand-soldered wire strain relief, 16-via 4x4 grid for inner-layer copper coupling. Replaces XT30 connector (OQ-008 catch — XT30 30A undersized for 70A cont / 100A burst spec). External XT90 connection wire (10-12 AWG silicone) solders into THT. Ampacity: 5x5mm 3oz copper + 16 vias @ 3A burst each = ~150A burst capacity. Phase 4-v3 Sai-locked 2026-05-26. Per IPC-2152 + JLC SMT capability.")
	(tags "battery solder pad high current wire XT90 hand solder strain relief")
